# ============ 米家控制 - 环境配置 ============

# 时区
TZ=Asia/Shanghai

# CORS 允许的来源（逗号分隔，无空格）
# 部署后改为你的外部域名，格式 https://your-domain.com
CORS_ORIGINS=http://localhost,http://127.0.0.1

# 域名（用于 HTTPS 证书申请和 nginx 配置）
DOMAIN=your-domain.example.com

# Let's Encrypt 证书申请邮箱
CERTBOT_EMAIL=your@email.com

# HTTP/HTTPS 端口（可选，默认 80 和 443）
HTTP_PORT=80
HTTPS_PORT=443

# ============ Tailscale（用于本地 MiIO 设备访问）============
# 在 https://login.tailscale.com/admin/settings/keys 生成 Auth Key
# TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxx
